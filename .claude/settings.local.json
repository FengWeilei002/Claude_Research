  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"ResearchVault 研究环境已就绪。当前项目：运筹学/理论经济学博士研究，重点方向：可再生能源供应链、机制设计、运营灵活性。数据目录 data/ 只读，输出目录 output/ 可写。\"}}'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"D:/research/ResearchVault\" && if [ -n \"$(git status --porcelain 2>/dev/null)\" ]; then echo '{\"systemMessage\":\"⚠️ 有未提交的更改，建议 git commit 保存进度\"}'; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' 2>/dev/null | { read -r f; case \"$f\" in *01_Literature/Reading_Notes/*.md) echo \"{\\\"systemMessage\\\":\\\"📝 文献笔记已创建: $(basename \"$f\" 2>/dev/null)。建议在 Obsidian 中添加 [[WikiLinks]] 关联到相关方法和想法笔记。\\\"}\" ;; esac; } 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "skipWebFetchPreflight": true
}
